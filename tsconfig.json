{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "react",
    "types": [
      "astro/client"
    ],
    "paths": {
      "~/*": [
        "src/*"
      ],
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": false,
    "incremental": true,
  },
  "include": [
    "**/*",
    ".astro/types.d.ts"
  ],
  "exclude": [
    "dist/"
  ]
}
