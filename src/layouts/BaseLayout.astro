---
import '~/assets/styles/tailwind.css';
import '~/assets/styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ForgeRealm',
  description = 'ForgeRealm powered by Astro'
} = Astro.props;

// Brevo Conversations widget — Conversations ID lives in .env.local as
// PUBLIC_BREVO_CONVERSATIONS_ID (grab it from app.brevo.com → Conversations →
// Settings → Install). Most visual tweaks (welcome message, agent avatar,
// auto-replies, business hours) are configured in the Brevo dashboard; what we
// override here is the embed-time setup so the launcher fits the site brand.
const brevoConversationsId = import.meta.env.PUBLIC_BREVO_CONVERSATIONS_ID;
---

<!doctype html>
<html lang="en" data-theme="dark" class="overflow-x-hidden">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0f1a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f5f0" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/frlogorv.png" />
    <meta property="og:site_name" content="ForgeRealm" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content="en_GB" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/frlogorv.png" />
    <link rel="icon" type="image/x-icon" href="/frlogo.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" as="image" href="/headfrlogorv.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <script is:inline src="/theme-init.js"></script>
  </head>
  <body class="min-h-[100dvh] md:min-h-[100svh] antialiased overflow-x-hidden" style={{ background: 'var(--background)', color: 'var(--foreground)' }}>
    <slot />

    <script is:inline>
      (() => {
        const targets = document.querySelectorAll('[data-observe]');
        if (!targets.length) return;
        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '120px 0px -10% 0px' }
        );
        targets.forEach((el) => observer.observe(el));
      })();
    </script>

    {brevoConversationsId && (
      <script is:inline define:vars={{ brevoConversationsId }}>
        // Pre-load setup so the widget is on-brand the moment it mounts.
        window.BrevoConversationsSetup = {
          buttonColor: '#3b82f6',
          buttonPosition: 'br',
          zIndex: 2147483646,
          locale: 'en',
        };
        (function (d, w, c) {
          w.BrevoConversationsID = brevoConversationsId;
          w[c] = w[c] || function () { (w[c].q = w[c].q || []).push(arguments); };
          var s = d.createElement('script');
          s.async = true;
          s.src = 'https://conversations-widget.brevo.com/brevo-conversations.js';
          if (d.head) d.head.appendChild(s);
        })(document, window, 'BrevoConversations');

        // Customer identity hook — Brevo's stub queues calls before the real
        // widget loads, so we can fire updateIntegrationData immediately.
        function identifyInBrevo(c) {
          if (!c || !window.BrevoConversations) return;
          var payload = {};
          if (c.email)     payload.email     = c.email;
          if (c.firstName) payload.firstName = c.firstName;
          if (c.lastName)  payload.lastName  = c.lastName;
          if (c.phone)     payload.phone     = c.phone;
          if (Object.keys(payload).length) {
            window.BrevoConversations('updateIntegrationData', payload);
          }
        }

        // Auto-identify from the shop's saved customer details, if present.
        try {
          var raw = localStorage.getItem('fr_customer');
          if (raw) identifyInBrevo(JSON.parse(raw));
        } catch (_) { /* ignore */ }

        // Re-identify when the saved details change (e.g. after checkout opts
        // in to save, or after a sign-in flow that writes fr_customer).
        window.addEventListener('storage', function (e) {
          if (e.key === 'fr_customer' && e.newValue) {
            try { identifyInBrevo(JSON.parse(e.newValue)); } catch (_) {}
          }
        });

        // Expose a manual hook so SignIn / checkout can identify on the same
        // tab (storage events only fire across tabs). Call:
        //   window.identifyCustomerInBrevo({ firstName, email, ... })
        window.identifyCustomerInBrevo = identifyInBrevo;

        // Brand-voice locale overrides. Brevo only exposes a few keys publicly;
        // anything missing here is controlled in the Brevo dashboard
        // (Conversations → Chat widget → Preferences / Localization).
        window.BrevoConversations('setLocale', {
          locale: 'en',
          translations: {
            'chat.placeholder': 'Drop us a message…',
            'chat.send': 'Send',
          },
        });
      </script>
    )}
  </body>
</html>
