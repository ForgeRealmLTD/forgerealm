---
import BaseLayout from '../layouts/BaseLayout.astro';
const publicApiUrl = import.meta.env.PUBLIC_API_URL || '';
const publicApiUrlLocal = import.meta.env.PUBLIC_API_URL_LOCAL || '';
---

<BaseLayout title="Subscribe | ForgeRealm" description="Subscribe to get notified about ForgeRealm booths, products, and offers.">
  <section class="min-h-screen bg-slate-950 text-white px-5 pb-12 relative overflow-hidden">
    {/* Enhanced ambient lighting for subscribe page */}
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-gradient-to-r from-blue-500/30 to-cyan-400/20 blur-[160px] animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 h-80 w-80 rounded-full bg-gradient-to-r from-fuchsia-500/25 to-purple-400/20 blur-[140px] animate-pulse" style={{ animationDelay: '1s' }} />
      <div class="absolute top-1/2 right-1/3 h-64 w-64 rounded-full bg-gradient-to-r from-indigo-500/20 to-blue-400/15 blur-[120px] animate-pulse" style={{ animationDelay: '2s' }} />

      {/* Floating particles */}
      <div class="absolute inset-0 overflow-hidden">
        {Array.from({ length: 15 }, (_, i) => (
          <div
            key={i}
            class="absolute w-1 h-1 bg-blue-400/40 rounded-full animate-bounce"
            style={{
              left: `${Math.random() * 100}%`,
              top: `${Math.random() * 100}%`,
              animationDelay: `${Math.random() * 3}s`,
              animationDuration: `${2 + Math.random() * 2}s`
            }}
          />
        ))}
      </div>
    </div>
    <div class="h-24 md:h-28" />
    <div class="mx-auto flex w-full max-w-6xl flex-wrap overflow-hidden rounded-3xl border border-white/10 bg-slate-900/60 shadow-2xl shadow-blue-500/10">
      {/* Left panel */}
      <div class="flex w-full flex-col md:w-1/2 lg:w-1/3">
        <div class="flex justify-center pt-10 md:justify-start md:pl-10 mb-6 md:mb-8">
          <a href="/" class="border-b-4 border-b-blue-500 pb-2 text-2xl font-bold text-white hover:text-blue-200 transition-colors">
            ForgeRealm
          </a>
        </div>
        <div class="my-auto flex flex-col justify-center px-6 pt-8 sm:px-14 md:justify-start md:px-8 md:pt-4 lg:px-10">
          <p class="text-center text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white via-blue-100 to-cyan-200 drop-shadow-lg">Stay in the Realm</p>
          <p class="mt-2 text-center text-slate-300">Get early drops, booth intel, and special offers.</p>
          <div class="pt-6 md:pt-10">
            <form
              id="subscribe-form"
              class="flex flex-col gap-5 rounded-2xl border border-white/10 bg-white/5 p-6 shadow-xl shadow-blue-500/10 backdrop-blur hover:bg-white/10 hover:border-blue-400/30 transition-all duration-300"
            >
              <label class="block text-sm text-white/80 font-semibold" for="subscribe-first-name">
                First Name
                <input
                  required
                  type="text"
                  name="firstName"
                  id="subscribe-first-name"
                  placeholder="Enter your name"
                  class="mt-2 w-full rounded-lg border border-white/10 bg-slate-900/70 px-3 py-2 text-white shadow-inner outline-none focus:border-blue-400 focus:ring-0 placeholder:text-white/40"
                />
              </label>

              <label class="block text-sm text-white/80 font-semibold" for="subscribe-last-name">
                Last Name
                <input
                  type="text"
                  name="lastName"
                  id="subscribe-last-name"
                  placeholder="Last name (optional)"
                  class="mt-2 w-full rounded-lg border border-white/10 bg-slate-900/70 px-3 py-2 text-white shadow-inner outline-none focus:border-blue-400 focus:ring-0 placeholder:text-white/40"
                />
              </label>

              <label class="block text-sm text-white/80 font-semibold" for="subscribe-email">
                Email Address
                <input
                  required
                  type="email"
                  name="email"
                  id="subscribe-email"
                  placeholder="you@example.com"
                  class="mt-2 w-full rounded-lg border border-white/10 bg-slate-900/70 px-3 py-2 text-white shadow-inner outline-none focus:border-blue-400 focus:ring-0 placeholder:text-white/40"
                />
              </label>

              <label class="block text-sm text-white/80 font-semibold" for="subscribe-company">
                Company
                <input
                  type="text"
                  name="company"
                  id="subscribe-company"
                  placeholder="Company (optional)"
                  class="mt-2 w-full rounded-lg border border-white/10 bg-slate-900/70 px-3 py-2 text-white shadow-inner outline-none focus:border-blue-400 focus:ring-0 placeholder:text-white/40"
                />
              </label>

              {/* Honeypot: hidden from real users, bots tend to fill it. */}
              <div aria-hidden="true" class="absolute -left-[10000px] top-auto h-px w-px overflow-hidden">
                <label>
                  Website
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <div class="pt-1 text-xs text-white/60">
                By joining, you'll receive updates about new products, services, offers, and booth events from ForgeRealm.
              </div>

              <button
                type="submit"
                class="relative mt-2 w-full overflow-hidden rounded-2xl p-[2px] focus:outline-none group"
              >
                {/* Multi-layered animated border */}
                <span class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#ffffff_0%,#3b82f6_20%,#06b6d4_40%,#3b82f6_60%,#ffffff_80%,#3b82f6_100%)]" />
                <span class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite_reverse] bg-[conic-gradient(from_90deg_at_50%_50%,#ffffff_0%,#06b6d4_25%,#3b82f6_50%,#06b6d4_75%,#ffffff_100%)] opacity-60" />

                {/* Inner glow */}
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-blue-500/20 via-cyan-400/20 to-blue-500/20 blur-sm group-hover:blur-md transition-all duration-300" />

                {/* Inner button */}
                <span class="relative inline-flex h-full w-full items-center justify-center rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 px-6 py-3 font-bold text-white backdrop-blur-3xl transition-all duration-300 group-hover:bg-gradient-to-br group-hover:from-blue-400 group-hover:to-indigo-500 gap-2 border border-white/20 group-hover:border-blue-400/50 group-hover:shadow-[0_0_40px_rgba(59,130,246,0.4)]">
                  Subscribe
                </span>
              </button>
            </form>
            <div
              id="subscribe-toast"
              class="hidden mt-6 rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100"
            >
              Thank you for your interest. You’ll receive an email from ForgeRealm shortly.
            </div>
            <div
              id="subscribe-error"
              class="hidden mt-6 rounded-2xl border border-rose-400/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-100"
            >
              <span id="subscribe-error-message">Something went wrong. Please try again.</span>
            </div>
          </div>
          <div class="pt-8 pb-10 text-center text-sm text-slate-300">
            <p class="whitespace-nowrap">
              Already in? <a href="/shop" class="font-semibold underline hover:text-white"> Explore the shop. </a>
            </p>
          </div>
        </div>
      </div>

      {/* Right panel */}
      <div class="pointer-events-none hidden select-none bg-black/60 md:block md:w-1/2 lg:w-2/3">
        <img
          class="h-full w-full object-cover opacity-90"
          src="/sub.jpg"
          alt="ForgeRealm"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ publicApiUrl, publicApiUrlLocal }}>
  const form = document.getElementById('subscribe-form');
  const toast = document.getElementById('subscribe-toast');
  const errorBox = document.getElementById('subscribe-error');
  const errorMessage = document.getElementById('subscribe-error-message');
  const submitButton = form?.querySelector('button[type="submit"]');
  const submitLabel = submitButton?.querySelector('span:last-child');
  const originalLabel = submitLabel?.textContent;
  const apiBase =
    window.location.origin.startsWith('http://localhost')
      ? (publicApiUrlLocal || publicApiUrl || '')
      : (publicApiUrl || publicApiUrlLocal || '');

  function showError(message) {
    if (!errorBox) return;
    if (errorMessage) errorMessage.textContent = message;
    errorBox.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    toast?.classList.add('hidden');
    errorBox?.classList.add('hidden');

    if (submitButton) submitButton.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Subscribing…';

    try {
      const data = new FormData(form);
      const payload = {
        firstName: data.get('firstName'),
        lastName: data.get('lastName'),
        email: data.get('email'),
        company: data.get('company'),
        website: data.get('website'),
      };

      const res = await fetch(`${apiBase}/api/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        form.reset();
        toast?.classList.remove('hidden');
        return;
      }

      let message = 'Something went wrong. Please try again.';
      if (res.status === 429) {
        message = 'Too many attempts. Please wait a minute and try again.';
      } else {
        const body = await res.json().catch(() => ({}));
        if (body?.error) message = body.error;
        else if (body?.message) message = body.message;
      }
      showError(message);
    } catch (_) {
      showError('Network error. Please check your connection and try again.');
    } finally {
      if (submitButton) submitButton.disabled = false;
      if (submitLabel && originalLabel) submitLabel.textContent = originalLabel;
    }
  });
</script>
